{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",        "value": "nosniff" },
        { "key": "X-Frame-Options",               "value": "DENY" },
        { "key": "X-XSS-Protection",              "value": "1; mode=block" },
        { "key": "Referrer-Policy",               "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",            "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",     "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",       "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:;" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ],
  "rewrites": [
    { "source": "/ops",      "destination": "/ops.html" },
    { "source": "/admin",    "destination": "/admin.html" },
    { "source": "/me",       "destination": "/me.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/login",    "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/dashboard", "destination": "/", "permanent": false }
  ]
}
